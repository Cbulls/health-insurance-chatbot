# ── harag PDF RAG MVP 설정 예시 ──
# 이 파일을 .env로 복사한 뒤 값을 채운다. 키가 없으면 로컬 폴백으로 동작한다
# (임베딩=결정적 해시, LLM=추출형) → 키 없이도 docker compose로 데모 가능.

# ── 임베딩 ──
# provider: openai(호환 API) | local(폴백). 미지정 시 키 유무로 자동 결정.
EMBEDDING_PROVIDER=
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# 모델 차원(text-embedding-3-small=1536, local 기본=512). 변경 시 컬렉션 재생성 필요.
EMBEDDING_DIM=
# true면 OpenAI /embeddings에 dimensions 파라미터 전달(차원 축소 → 저장량 절감).
# OpenAI text-embedding-3-* 전용. 다른 호환 프로바이더는 미지원일 수 있어 기본 꺼짐.
EMBEDDING_SEND_DIMENSIONS=

# ── LLM ──
# provider: openai(호환 API) | local(폴백). 미지정 시 키 유무로 자동 결정.
# 국내 행정문서 데이터 주권이 중요하면 Upstage Solar 등 OpenAI 호환 게이트웨이 권장:
#   LLM_API_BASE=https://api.upstage.ai/v1  LLM_MODEL=solar-pro
LLM_PROVIDER=
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# 멀티턴 질의 재작성: 질의마다 LLM을 한 번 더 부른다. false로 끄거나,
# 답변보다 싸고 빠른 모델로 분리 가능(비면 LLM_MODEL 사용).
LLM_REWRITE_ENABLED=true
LLM_REWRITE_MODEL=

# ── Gemini(Google AI Studio) 사용 시 권장 조합 ──
# Gemini는 OpenAI 호환 레이어로 chat·스트리밍·임베딩을 모두 지원한다:
#   LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-flash-latest        # 계정별 가용 모델은 /models로 확인
#   LLM_REWRITE_MODEL=gemini-flash-lite-latest
#   EMBEDDING_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
#   EMBEDDING_API_KEY=<같은 Gemini 키>
#   EMBEDDING_MODEL=gemini-embedding-001
#   EMBEDDING_DIM=768  EMBEDDING_SEND_DIMENSIONS=true
#   RATE_LIMIT_QPM=8   # 무료 등급 ~10 RPM 아래로

# ── Qdrant ──
# 비우면 인메모리(:memory:, 단일 프로세스). docker compose에서는 http://qdrant:6333.
# Qdrant Cloud는 클러스터 URL(https://xxx.cloud.qdrant.io:6333) + API 키 필요.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=harag_pdf_mvp
# 디스크 예산(MB). 이 예산을 넘길 인덱싱은 거부(capacity_exceeded). 0이면 비활성.
# 무료 사양(4GiB 디스크) 기준 3072 = 75%(공식 80% 경고선 아래 안전 마진).
QDRANT_DISK_BUDGET_MB=3072
# 청크(포인트)당 payload 예상 크기(바이트). 예산→최대 포인트 수 역산에 사용.
QDRANT_PAYLOAD_BYTES_PER_POINT=2048

# ── Qdrant Cloud 무료 사양(1 node, 1GiB RAM, 4GiB Disk, 0.5 vCPU) 권장 조합 ──
# 무료 클러스터는 자동 과금·자동 업그레이드가 없다. 한도를 넘으면 과금 대신
# 저장 실패·장애가 나므로, 아래 조합으로 한도 안에서 안전하게 운용한다:
#   QDRANT_URL=https://<cluster-id>.<region>.cloud.qdrant.io:6333
#   QDRANT_API_KEY=<cloud api key>
#   QDRANT_DISK_BUDGET_MB=3072
#   EMBEDDING_DIM=512                  # 1536→512 축소 시 저장량 약 3배 절감
#   EMBEDDING_SEND_DIMENSIONS=true     # OpenAI text-embedding-3-* 사용 시
# 원격 컬렉션은 자동으로 저자원 구성(벡터·HNSW·payload 디스크 + int8 양자화 RAM)
# 으로 생성된다. 기존 컬렉션에는 적용되지 않으므로 삭제 후 재인덱싱 필요.

# ── 검색/생성 파라미터 ──
TOP_K=20
MIN_SCORE=0.15
MAX_UPLOAD_BYTES=104857600
# LLM 리랭커: 질의마다 저비용 LLM 한 번으로 검색 후보를 정밀 재순위.
# false면(또는 LLM 키 없으면) 어휘 겹침 리랭커 폴백. 모델 비면 REWRITE→LLM_MODEL 순.
RERANK_LLM_ENABLED=true
RERANK_LLM_MODEL=

# ── 보호 장치 ──
# owner별 분당 요청 상한(query·업로드). 0이면 비활성.
# Gemini 무료 등급(~10 RPM)을 쓸 때는 8 이하로 낮춰 프로바이더 429를 예방.
RATE_LIMIT_QPM=20
# CORS 허용 오리진(콤마 구분). 비우면 교차 오리진 차단(프론트는 같은 오리진 서빙).
ALLOWED_ORIGINS=

# ── 인증(JWT, 선택) ──
# 설정하면 Bearer JWT 검증을 강제한다(fail-closed). 비우면 X-Owner-Id 헤더 모드(로컬 데모).
AUTH_JWT_SECRET=
AUTH_JWT_ALGORITHMS=HS256
AUTH_JWT_AUDIENCE=
AUTH_JWT_ISSUER=

# ── 문서 등록부(메타 DB) ──
# 기본(추천·로컬): SQLite 파일. 비우거나 아래 기본값이면 ./data/harag.db에 영속화.
# 서버 재시작 후에도 문서 목록이 유지된다. 별도 설정 불필요.
DATABASE_URL=sqlite:///./data/harag.db
# PostgreSQL 사용 시:
#   1) docker compose --profile postgres up -d postgres
#   2) DATABASE_URL=postgresql+psycopg://harag:harag@localhost:5432/harag
#   3) pip install 'psycopg[binary]>=3.1'  또는  pip install -e '.[postgres]'
# 첫 기동 시 테이블 자동 생성(create_all). 예전 인메모리만 쓰던 목록은 DB에 없으므로 재업로드 필요.
