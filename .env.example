# ── harag PDF RAG MVP 설정 예시 ──
# 이 파일을 .env로 복사한 뒤 값을 채운다. 키가 없으면 로컬 폴백으로 동작한다
# (임베딩=결정적 해시, LLM=추출형) → 키 없이도 docker compose로 데모 가능.

# ── 임베딩 ──
# provider: openai(호환 API) | local(폴백). 미지정 시 키 유무로 자동 결정.
EMBEDDING_PROVIDER=
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# 모델 차원(text-embedding-3-small=1536, local 기본=512). 변경 시 컬렉션 재생성 필요.
EMBEDDING_DIM=
# true면 OpenAI /embeddings에 dimensions 파라미터 전달(차원 축소 → 저장량 절감).
# OpenAI text-embedding-3-* 전용. 다른 호환 프로바이더는 미지원일 수 있어 기본 꺼짐.
EMBEDDING_SEND_DIMENSIONS=

# ── LLM ──
# provider: openai(호환 API) | local(폴백). 미지정 시 키 유무로 자동 결정.
# 국내 행정문서 데이터 주권이 중요하면 Upstage Solar 등 OpenAI 호환 게이트웨이 권장:
#   LLM_API_BASE=https://api.upstage.ai/v1  LLM_MODEL=solar-pro
LLM_PROVIDER=
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# 멀티턴 질의 재작성: 질의마다 LLM을 한 번 더 부른다. false로 끄거나,
# 답변보다 싸고 빠른 모델로 분리 가능(비면 LLM_MODEL 사용).
LLM_REWRITE_ENABLED=true
LLM_REWRITE_MODEL=

# ── Gemini(Google AI Studio) 사용 시 권장 조합 ──
# 상세: docs/GEMINI_COST_STRATEGY.md
# Gemini는 OpenAI 호환 레이어로 chat·스트리밍·임베딩을 모두 지원한다:
#   LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-flash-latest        # Pro 금지. 계정별 가용 모델은 /models로 확인
#   LLM_REWRITE_MODEL=gemini-flash-lite-latest
#   EMBEDDING_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
#   EMBEDDING_API_KEY=<같은 Gemini 키>
#   EMBEDDING_MODEL=gemini-embedding-001
#   EMBEDDING_DIM=768  EMBEDDING_SEND_DIMENSIONS=true
#   RATE_LIMIT_QPM=5   # 질문당 최대 3콜 → Gemini ~10 RPM 아래로
#   LLM_MAX_COST_PER_QUERY_USD=0.05
#   LLM_MAX_RETRIES=1  # 무료 티어 429 증폭 완화
# 결제(Billing)는 MVP에서 연결하지 말 것 — 미연결이면 토큰 과금 0.

# ── Qdrant ──
# 비우면 인메모리(:memory:, 단일 프로세스). docker compose에서는 http://qdrant:6333.
# Qdrant Cloud는 클러스터 URL(https://xxx.cloud.qdrant.io:6333) + API 키 필요.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=harag_pdf_mvp
# 디스크 예산(MB). 이 예산을 넘길 인덱싱은 거부(capacity_exceeded). 0이면 비활성.
# 무료 사양(4GiB 디스크) 기준 3072 = 75%(공식 80% 경고선 아래 안전 마진).
QDRANT_DISK_BUDGET_MB=3072
# 청크(포인트)당 payload 예상 크기(바이트). 슬림 v2 기준 기본 1536.
QDRANT_PAYLOAD_BYTES_PER_POINT=1536
# 하이브리드 sparse 예상 바이트·세그먼트 배수(용량 공식 보정).
QDRANT_SPARSE_BYTES_PER_POINT=640
QDRANT_SEGMENT_FACTOR=1.15
# 대문서 upsert 배치 크기 / approximate count 캐시 TTL(초).
QDRANT_UPSERT_BATCH_SIZE=64
QDRANT_COUNT_CACHE_TTL_S=5
# 하이브리드 prefetch = TOP_K * HYBRID_PREFETCH_MULT (기본 2).
HYBRID_PREFETCH_MULT=2

# ── Qdrant Cloud 무료 사양(1 node, 1GiB RAM, 4GiB Disk, 0.5 vCPU) 권장 조합 ──
# 무료 클러스터는 자동 과금·자동 업그레이드가 없다. 한도를 넘으면 과금 대신
# 저장 실패·장애가 나므로, 아래 조합으로 한도 안에서 안전하게 운용한다:
#   QDRANT_URL=https://<cluster-id>.<region>.cloud.qdrant.io:6333
#   QDRANT_API_KEY=<cloud api key>
#   QDRANT_DISK_BUDGET_MB=3072
#   EMBEDDING_DIM=512                  # 1536→512 축소 시 저장량 약 3배 절감
#   EMBEDDING_SEND_DIMENSIONS=true     # OpenAI text-embedding-3-* / Gemini 권장
#   QDRANT_COLLECTION=harag_pdf_512    # 차원 변경 시 새 이름 권장
# 원격 컬렉션은 자동으로 저자원 구성(벡터·HNSW·payload 디스크 + int8 양자화 RAM)
# 으로 생성된다. 기존 컬렉션에는 적용되지 않으므로 삭제 후 재인덱싱 필요.

# ── Redis(선택) ──
# 설정 시: Streams 인제스트 큐·문서 상태 캐시·레이트제한·대화이력을 Redis로 공유.
# 비우면 인메모리 폴백(API 인프로세스 인제스트, 워커 불필요).
# docker compose: redis://redis:6379/0
# 로컬 API + compose Redis: redis://localhost:6379/0
REDIS_URL=
# 키 네임스페이스(모든 Redis 키에 공통 접두사).
REDIS_KEY_PREFIX=harag:
# 인제스트 스트림 approximate MAXLEN.
REDIS_STREAM_MAXLEN=10000
# PEL idle(초) 후 XAUTOCLAIM으로 메시지 회수.
INGEST_VISIBILITY_SEC=120
# 워커 실패 재시도 상한(이후 DLQ 스트림).
INGEST_MAX_ATTEMPTS=3
# API↔워커가 업로드 스풀 파일을 공유할 디렉터리(compose는 /app/spool).
# REDIS_URL이 있으면 필수(없으면 API 기동 fail-fast).
HARAG_SPOOL_DIR=

# ── 파서·DOC 변환 ──
# HWP5 표 복원율이 이 값 미만이면 ready + 경고(검색은 가능, HWPX 권고).
PARSE_MIN_TABLE_RECOVERY=0.5
# 구형 .doc → LibreOffice headless DOCX 변환.
ENABLE_DOC_CONVERT=true
LIBREOFFICE_BIN=soffice
DOC_CONVERT_TIMEOUT_SEC=120

# ── 검색/생성 파라미터 ──
TOP_K=20
MIN_SCORE=0.15
MAX_UPLOAD_BYTES=104857600
# LLM 리랭커: 질의마다 저비용 LLM 한 번으로 검색 후보를 정밀 재순위.
# false면(또는 LLM 키 없으면) 어휘 겹침 리랭커 폴백. 모델 비면 REWRITE→LLM_MODEL 순.
RERANK_LLM_ENABLED=true
RERANK_LLM_MODEL=

# ── 리랭커 (Cross-Encoder) ──
# RERANK_ENABLED=false 이면 리랭크 생략(검색 top_k를 생성기가 그대로 봄 — 비권장).
RERANK_ENABLED=true
# TEI/vLLM 호환 서버 URL. 비우면 LexicalCrossEncoder(어절 겹침) 폴백.
# 예: RERANKER_SERVER_URL=http://127.0.0.1:8080
RERANKER_SERVER_URL=
RERANK_TOP_N=5
RERANK_TIMEOUT_MS=3000
# 리랭커 자체 필터. 비우면(-1 센티널) HTTP CE일 때 MIN_SCORE, Lexical일 때 0.
# RERANK_MIN_SCORE=
# retrieval 점수 블렌드(0=CE만, 1=retrieval만). 비우면 HTTP=0, Lexical=0.7.
# RETRIEVAL_BLEND=
# 동시 질의 ≥ N이면 under_load로 CE 입력 K 축소(RR-04).
RERANK_UNDER_LOAD_INFLIGHT=4
# 생성 전 중복·거의 동일 청크 제거.
CONTEXT_DEDUPE=true

# ── 보호 장치 ──
# owner별 분당 요청 상한(query·업로드). 0이면 비활성.
# Gemini 무료(~10 RPM)·질문당 최대 3콜 → 기본 5 이하(docs/GEMINI_COST_STRATEGY.md).
RATE_LIMIT_QPM=5
# 답변 LLM 예상 비용 상한(휴리스틱). 유료 전환 시에도 폭주 차단.
LLM_MAX_COST_PER_QUERY_USD=0.05
LLM_COST_PER_1K_TOKENS=0.01
# 429 재시도 횟수(0=재시도 없음). 무료 티어는 1 권장.
LLM_MAX_RETRIES=1
# 재작성 프롬프트 문자 상한.
LLM_REWRITE_MAX_CHARS=2000
# CORS 허용 오리진(콤마 구분). 비우면 교차 오리진 차단(프론트는 같은 오리진 서빙).
ALLOWED_ORIGINS=

# ── 인증(JWT / OIDC, 선택) ──
# AUTH_OIDC_JWKS_URL 또는 AUTH_JWT_SECRET 설정 시 Bearer 검증 강제(fail-closed).
AUTH_JWT_SECRET=
AUTH_JWT_ALGORITHMS=HS256
AUTH_JWT_AUDIENCE=
AUTH_JWT_ISSUER=
# 예: https://login.example.com/oauth2/v1/keys
AUTH_OIDC_JWKS_URL=
# 운영은 false — X-Owner-Id 데모 헤더 차단
AUTH_ALLOW_DEMO_OWNER=true

# ── PII · 일일 예산 ──
PII_MASK_ENABLED=true
# 0=비활성. Gemini RPD 기준으로 scripts/gemini_quota_budget.py 참고.
DAILY_QUESTION_BUDGET=0
DAILY_TOKEN_BUDGET=0

# ── Object Store (원본 보존, 선택) ──
# docker compose --profile minio|ops 후:
#   OBJECT_STORE_ENDPOINT=http://minio:9000
#   OBJECT_STORE_ACCESS_KEY=minioadmin
#   OBJECT_STORE_SECRET_KEY=minioadmin
OBJECT_STORE_ENDPOINT=
OBJECT_STORE_ACCESS_KEY=
OBJECT_STORE_SECRET_KEY=
OBJECT_STORE_BUCKET=harag-originals
OBJECT_STORE_REGION=us-east-1

# ── OCR 정책 ──
# 표본 스캔 비율 ≥ 이 값이면 OCR 도입 권고(docs/OCR_POLICY.md)
OCR_SCAN_RATIO_THRESHOLD=0.15

# ── 문서 등록부(메타 DB) ──
# 기본(추천·로컬): SQLite 파일. 비우거나 아래 기본값이면 ./data/harag.db에 영속화.
# 서버 재시작 후에도 문서 목록이 유지된다. 별도 설정 불필요.
DATABASE_URL=sqlite:///./data/harag.db
# PostgreSQL 사용 시:
#   1) docker compose --profile postgres up -d postgres
#   2) DATABASE_URL=postgresql+psycopg://harag:harag@localhost:5432/harag
#   3) pip install 'psycopg[binary]>=3.1'  또는  pip install -e '.[postgres]'
# 첫 기동 시 테이블 자동 생성(create_all). 예전 인메모리만 쓰던 목록은 DB에 없으므로 재업로드 필요.
# 운영 묶음: docker compose --profile ops up --build
#   DATABASE_URL=postgresql+psycopg://harag:harag@postgres:5432/harag
#   OBJECT_STORE_ENDPOINT=http://minio:9000

